{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/ats-kinoshita-iso/spec-learner/examples/scheduling/output.schema.json",
  "title": "Weekly timeline",
  "description": "Concrete output schema for the scheduling/weekly-timeline task. Authoritative for harness output validation.",
  "type": "object",
  "additionalProperties": false,
  "required": ["days"],
  "properties": {
    "days": {
      "type": "array",
      "minItems": 7,
      "maxItems": 7,
      "description": "Exactly seven days, ordered Monday through Sunday.",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["day", "date", "assignments"],
        "properties": {
          "day": {
            "type": "string",
            "enum": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday", "Sunday"]
          },
          "date": {
            "type": "string",
            "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
          },
          "assignments": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    }
  }
}
